# ==========================================
# ODIN: Tactical Overwatch Configuration
# ==========================================

# --- POSTGIS DATABASE ---
DB_HOST=db
DB_NAME=osint_dashboard
DB_USER=postgres
DB_PASS=ChangeThisToASecurePassword123!

# --- C# API SETTINGS ---
ASPNETCORE_ENVIRONMENT=Development
# Connection string uses the DB_ variables above. Update port if not running in Docker network.
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=osint_dashboard;Username=postgres;Password=ChangeThisToASecurePassword123!

# --- PYTHON WORKER (MESHTASTIC HARDWARE) ---
# Connection Type: 'serial' (USB) or 'tcp' (WiFi)
RADIO_CONNECTION_TYPE=serial
# Linux/Pi typically uses /dev/ttyUSB0 or /dev/ttyACM0. Windows uses COM3, COM4, etc.
RADIO_PORT=/dev/ttyUSB0
# Only required if RADIO_CONNECTION_TYPE=tcp
RADIO_IP=192.168.1.100

# --- FRONTEND SETTINGS ---
# The URL where the Vite app expects to find the API
VITE_API_BASE_URL=http://localhost:8080/api/v1